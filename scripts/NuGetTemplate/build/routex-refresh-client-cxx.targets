<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <routex-refresh-client-cxxRuntimesDir>$(MSBuildThisFileDirectory)..\runtimes\</routex-refresh-client-cxxRuntimesDir>

    <routex-refresh-client-cxxRid Condition="'$(Platform)' == 'x64'">win-x64</routex-refresh-client-cxxRid>
    <routex-refresh-client-cxxRid Condition="'$(Platform)' == 'Win32'">win-x86</routex-refresh-client-cxxRid>
    <routex-refresh-client-cxxRid Condition="'$(Platform)' == 'ARM64'">win-arm64</routex-refresh-client-cxxRid>
    <!-- Default to x64 -->
    <routex-refresh-client-cxxRid Condition="'$(routex-refresh-client-cxxRid)' == ''">win-x64</routex-refresh-client-cxxRid>

    <routex-refresh-client-cxxNativeDir Condition="'$(Configuration)' == 'Debug'">$(routex-refresh-client-cxxRuntimesDir)$(routex-refresh-client-cxxRid)\native\debug\</routex-refresh-client-cxxNativeDir>
    <routex-refresh-client-cxxNativeDir Condition="'$(Configuration)' != 'Debug'">$(routex-refresh-client-cxxRuntimesDir)$(routex-refresh-client-cxxRid)\native\</routex-refresh-client-cxxNativeDir>
  </PropertyGroup>

  <!-- Copy the DLL to the output directory -->
  <ItemGroup>
    <None Include="$(routex-refresh-client-cxxNativeDir)routex_refresh_client_cxx.dll" Condition="Exists('$(routex-refresh-client-cxxNativeDir)routex_refresh_client_cxx.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </None>
    <!-- Copy PDB only for debug builds -->
    <None Include="$(routex-refresh-client-cxxNativeDir)routex_refresh_client_cxx.pdb" Condition="Exists('$(routex-refresh-client-cxxNativeDir)routex_refresh_client_cxx.pdb') And '$(Configuration)' == 'Debug'">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </None>
  </ItemGroup>
</Project>
